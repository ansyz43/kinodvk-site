---
import Layout from "../layouts/Layout.astro";
import ArchiveBento from "../components/ui/archive-bento";

type Film = { cat: string; title: string; meta: string; region?: string; winner?: boolean; big?: boolean; img?: string };

type Year = { num: string; label: string; place: string; date: string; films: Film[] };

const years: Year[] = [
  {
    num: "2024",
    label: "I сезон",
    place: "Москва",
    date: "Декабрь 2024",
    films: [
      { cat: "Лучший полнометражный фильм", title: "Сто лет тому вперёд", meta: "Алексей Нужный · 2024", region: "Якутия / Приморье", winner: true, big: true, img: "/assets/gallery/2024/3K6A1474_resized.jpg" },
      { cat: "Лучшая режиссёрская работа",  title: "Айта", meta: "Степан Бурнашёв · 2022", region: "Якутия", winner: true, img: "/assets/gallery/2024/3K6A2040_resized.jpg" },
      { cat: "Лучший сценарий", title: "Не одна дома", meta: "Радда Новикова · 2023", region: "Сахалин" },
      { cat: "Лучший дебют", title: "Куба, Куба", meta: "Кирилл Кравченко · 2024", region: "Приморье" },
      { cat: "Лучший короткометражный фильм", title: "Тойук", meta: "Виктор Аммосов · 2023", region: "Якутия" },
      { cat: "За вклад в развитие", title: "Дмитрий Давыденко", meta: "Продюсер · Якутск", region: "Якутия", winner: true },
    ],
  },
  {
    num: "2025",
    label: "II сезон",
    place: "Улан-Удэ",
    date: "Сентябрь 2025",
    films: [
      { cat: "Лучший полнометражный фильм", title: "Огонь",  meta: "Алексей Нужный · 2024", region: "Камчатка", winner: true, big: true, img: "/assets/gallery/2025/LX3A5728_resized.jpg" },
      { cat: "Лучшая режиссёрская работа",  title: "Чёрная молния возвращается", meta: "Дмитрий Давыдов · 2024", region: "Якутия", winner: true, img: "/assets/gallery/2025/LX3A5746_resized.jpg" },
      { cat: "Лучший сценарий", title: "Бэлэх", meta: "Степан Бурнашёв · 2024", region: "Якутия" },
      { cat: "Лучший дебют", title: "Триозёрск", meta: "Сергей Кузнецов · 2024", region: "Хабаровск" },
      { cat: "Лучший короткометражный фильм", title: "Куда мы едем", meta: "Татьяна Эверстова · 2024", region: "Якутия" },
      { cat: "За вклад в развитие", title: "Алёна Шумакова", meta: "Программный директор · Бурятия", region: "Бурятия", winner: true },
    ],
  },
  {
    num: "2026",
    label: "III сезон",
    place: "Хабаровск",
    date: "25 сентября 2026",
    films: [
      { cat: "Полный метр", title: "Шорт-лист откроется в&nbsp;июне", meta: "После приёма заявок", big: true },
      { cat: "Режиссура",   title: "Шорт-лист откроется в&nbsp;июне", meta: "После приёма заявок" },
      { cat: "Сценарий",    title: "Шорт-лист откроется в&nbsp;июне", meta: "После приёма заявок" },
      { cat: "Дебют",       title: "Шорт-лист откроется в&nbsp;июне", meta: "После приёма заявок" },
      { cat: "Короткий метр", title: "Шорт-лист откроется в&nbsp;июне", meta: "После приёма заявок" },
      { cat: "Арктика — новая номинация", title: "Шорт-лист откроется в&nbsp;июне", meta: "Фильмы о&nbsp;Крайнем Севере" },
    ],
  },
];
---
<Layout title={`Архив · Дальневосточная Кинопремия 2026`} active={"archive"}>

<section class="page-hero v2">
  <div class="page-hero-eyebrow"><span class="dot"></span><span>Архив победителей</span></div>
  <h1 class="page-hero-title" data-text-reveal>Три <em>сезона</em></h1>
  <p class="page-hero-lead">Шорт-листы и&nbsp;победители прошедших церемоний. Сезон 2026 откроется после приёма заявок и&nbsp;работы экспертного совета.</p>
</section>

<div class="archive-layout">
  <aside class="year-scrubber" data-year-scrubber>
    <div class="year-scrubber-label">Сезоны</div>
    {years.map((y) => (
      <button type="button" data-year-target={"#year-" + y.num} class="year-scrubber-btn">
        <span class="year-scrubber-num">{y.num}</span>
        <span class="year-scrubber-place">{y.place}</span>
      </button>
    ))}
  </aside>

  <div class="archive-years">
    {years.map((y) => (
      <section class="archive-year-block" id={"year-" + y.num}>
        <header class="archive-year-head-v2">
          <div class="archive-year-mark">
            <span class="archive-year-num-big">{y.num}</span>
            <span class="archive-year-label">{y.label} · {y.place}</span>
          </div>
          <div class="archive-year-date">{y.date}</div>
        </header>

        <ArchiveBento year={y.num as "2024" | "2025" | "2026"} client:visible />
      </section>
    ))}
  </div>
</div>

</Layout>
